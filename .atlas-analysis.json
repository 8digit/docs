  "keyFeatures": [
    "Visual node-based canvas for building AI pipelines",
    "Image generation nodes (multiple models via registry)",
    "Video generation nodes (Kling, Seedance, and more)",
    "Music/audio generation nodes (Suno and others)",
    "AI Assistant node (Claude, OpenAI, Gemini)",
    "HTTP Request node for connecting external APIs",
    "Deploy workflows as callable REST API endpoints",
    "Public playground sharing for workflows",
    "Credit-based billing with tier plans",
    "Per-user API keys with scope-based access control",
    "Media upload and S3-backed storage",
    "Workflow folders for organization"
  ],
